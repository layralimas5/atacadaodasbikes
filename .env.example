# ===== Atendente de IA (NÃO comitar o .env de verdade) =====
# Copie este arquivo para .env e preencha. Em produção, configure estas
# variáveis no painel da Netlify (Site settings > Environment variables).

# --- Cérebro da IA (Google Gemini — plano gratuito) ---
# Crie a chave grátis em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo (opcional). Padrão: gemini-2.5-flash (rápido e gratuito).
# GEMINI_MODEL=gemini-2.5-flash

# --- WhatsApp (Fase 2 — Meta Cloud API). Deixe vazio até configurar a Meta. ---
# Token que VOCÊ inventa e cola também no painel da Meta ao criar o webhook:
WHATSAPP_VERIFY_TOKEN=
# Access token da Cloud API (Meta > WhatsApp > API Setup):
WHATSAPP_TOKEN=
# ID do número remetente (Meta > WhatsApp > API Setup > Phone number ID):
WHATSAPP_PHONE_NUMBER_ID=
